# Copy this file to .env.local for local development
# Add these same keys in Vercel Dashboard → Project → Settings → Environment Variables

# Required
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<appName>
OPENAI_API_KEY=sk-proj-...

# Optional — defaults shown below, override to swap models without any code changes
OPENAI_CHAT_MODEL=gpt-4.1
QUERY_EXPANSION_MODEL=gpt-4.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
